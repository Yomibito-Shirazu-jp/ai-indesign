{
  "manifestVersion": 5,
  "id": "com.yomibitoshirazujp.ai-indesign",
  "name": "Ai-inDesign",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "ID",
    "minVersion": "18.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": { "default": "Bridge Panel" }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": ["ws://127.0.0.1:49300", "http://127.0.0.1:49300", "ws://localhost:49300", "http://localhost:49300", "ws://127.0.0.1:*", "ws://localhost:*"]
    },
    "allowCodeGenerationFromStrings": true
  }
}
