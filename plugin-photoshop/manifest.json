{
  "manifestVersion": 5,
  "id": "com.yomibitoshirazujp.ai-photoshop",
  "name": "Ai-inDesign for Photoshop",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": { "default": "Ai-inDesign" }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": ["ws://127.0.0.1:49302", "http://127.0.0.1:49302", "ws://localhost:49302", "http://localhost:49302", "ws://127.0.0.1:*", "ws://localhost:*"]
    },
    "allowCodeGenerationFromStrings": true
  }
}
